msgctxt "model:ir.message,text:msg_file_generate_uri_missing_endpoint"
msgid "Missing file wrapper endpoint for file URI generation."
msgstr ""
"Falta el punto final del contenedor de archivos para la generación de URI de"
" archivos."

msgctxt "model:ir.message,text:msg_file_generate_uri_missing_site"
msgid "Please set a site before generating URIs for file \"%(file)s\"."
msgstr ""
"Por favor, configure un sitio antes de generar URI para el archivo "
"\"%(file)s\"."

msgctxt "model:ir.message,text:msg_page_generate_uri_missing_endpoint"
msgid "Missing content wrapper endpoint for page URI generation."
msgstr ""
"Falta el endpoint del contenedor de contenido para generar el URI de la "
"página."

msgctxt "model:ir.message,text:msg_page_generate_uri_missing_site"
msgid "Please set a site before generating URIs for page \"%(page)s\"."
msgstr ""
"Por favor, configure un sitio antes de generar URI para la página "
"\"%(page)s\"."

msgctxt "model:ir.message,text:msg_page_main_uri_unique"
msgid "Only one main URI can be selected for page \"%(page)s\"."
msgstr "Solo se puede seleccionar una URI principal para la página \"%(page)s\"."

msgctxt "model:ir.message,text:msg_page_missing_draft"
msgid "The published page \"%(page)s\" has no linked draft."
msgstr "La página publicada \"%(page)s\" no tiene ningún borrador vinculado."

