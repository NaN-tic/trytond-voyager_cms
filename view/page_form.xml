<form>
    <group col="4" colspan="4" xalign="0.0" xexpand="1" xfill="1" id="page_header">
        <notebook colspan="4">
            <page string="Page" id="components">
                <label name="name" xalign="0.0"/>
                <field name="name" xexpand="1" xfill="1"/>
                <label name="site" xalign="0.0"/>
                <field name="site" xexpand="1" xfill="1"/>
                <label name="uri_es" xalign="0.0"/>
                <field name="uri_es" xexpand="1" xfill="1"/>
                <label name="main_uri_es" xalign="0.0" xexpand="0" xfill="0"/>
                <field name="main_uri_es" xexpand="0" xfill="0"/>
                <label name="uri_en" xalign="0.0"/>
                <field name="uri_en" xexpand="1" xfill="1"/>
                <label name="main_uri_en" xalign="0.0" xexpand="0" xfill="0"/>
                <field name="main_uri_en" xexpand="0" xfill="0"/>
                <label name="uri_ca" xalign="0.0"/>
                <field name="uri_ca" xexpand="1" xfill="1"/>
                <label name="main_uri_ca" xalign="0.0" xexpand="0" xfill="0"/>
                <field name="main_uri_ca" xexpand="0" xfill="0"/>

                <group id="buttons" col="1" colspan="4">
                    <button name="generate_uri"/>
                </group>

                <separator string="" colspan="4"/>
                <field name="component" colspan="4" mode="tree,form"
                    view_ids="voyager_cms.www_component_view_tree_sequence,voyager_cms.www_component_view_form"/>
            </page>
            <page string="Page Preview" id="page_preview">
                <field name="preview" widget="document" colspan="4" height="700"/>
            </page>
        </notebook>
    </group> 
</form>
