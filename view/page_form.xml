<form>
    <notebook colspan="4">
        <page string="Properties" id="properties">
            <label name="name"/>
            <field name="name"/>
            <label name="site"/>
            <field name="site"/>
            <label name="state"/>
            <field name="state"/>
            <group col="-1" colspan="2" id="buttons">
                <button name="draft"/>
                <button name="publish"/>
            </group>
            <field name="element" colspan="4" mode="tree,list-form,form" height="900"/>
        </page>
        <page string="Preview" id="preview">
            <field name="preview" widget="document" colspan="4" height="900"/>
        </page>
        <page string="Uris" id="uris">
            <label name="origin_page" />
            <field name="origin_page"/>
            <label name="published_page" />
            <field name="published_page"/>
            <label name="main_uri_language"/>
            <field name="main_uri_language"/>
            <field name="uris" colspan="4" mode="tree,form" height="250"/>
            <group id="buttons" col="1" colspan="4">
                <button name="generate_uri"/>
            </group>
        </page>
    </notebook>
</form>
