<form>
    <notebook colspan="4">
        <page string="Properties" id="properties">
            <label name="page"/>
            <field name="page"/>
            <newline/>
            <label name="name"/>
            <field name="name"/>
            <label name="sequence"/>
            <field name="sequence"/>
            <field name="valid_models" invisible="1" colspan="4"/>
            <label name="model"/>
            <field name="model"/>
            <newline/>
            <label name="show_preview_fields"/>
            <field name="show_preview_fields"/>
            <newline/>
            <field name="schema" mode="form,tree" colspan="4"/>
        </page>
        <page string="Preview" id="preview">
            <field name="preview" widget="document" colspan="4" height="600"/>
        </page>
    </notebook>
</form>
